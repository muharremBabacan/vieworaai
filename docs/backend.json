
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the Viewora AI Coach application, storing their profile information, token balance, and gamification level.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "auro_balance": { "type": "number" },
        "total_auro_spent": { "type": "number", "default": 0 },
        "total_analyses_count": { "type": "number", "default": 0 },
        "level_name": { "type": "string" },
        "current_xp": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "lastNotificationsViewedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "auro_balance", "level_name", "current_xp", "createdAt"]
    },
    "AnalysisLog": {
      "title": "Analysis Log",
      "type": "object",
      "description": "Individual record of every AI analysis performed for cost and usage tracking.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["technical", "mentor"] },
        "auroSpent": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["userId", "type", "auroSpent", "timestamp"]
    },
    "GroupAssignment": {
      "title": "Group Assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "GroupSubmission": {
      "title": "Group Submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "assignmentId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhotoURL": { "type": "string", "format": "uri" },
        "photoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "likes": { "type": "array", "items": { "type": "string" } },
        "comments": {
          "type": "array",
          "items": {
            "object": {
              "properties": {
                "userId": { "type": "string" },
                "userName": { "type": "string" },
                "text": { "type": "string" },
                "createdAt": { "type": "string" }
              }
            }
          }
        },
        "submittedAt": { "type": "string" }
      }
    },
    "Trip": {
      "title": "Group Trip (Photo Walk)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startPoint": { "type": "string" },
        "endPoint": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "distance": { "type": "string" },
        "approvalRequired": { "type": "boolean" },
        "isListPublic": { "type": "boolean" },
        "status": { "type": "string", "enum": ["planned", "completed", "cancelled", "archived"] },
        "created_at": { "type": "string" },
        "completed_at": { "type": "string" },
        "cancelled_at": { "type": "string" }
      }
    },
    "TripParticipant": {
      "title": "Trip Participant",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhotoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "yes", "no"] },
        "joined_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "joined_at"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and aggregate usage counts."
    },
    "groups/{groupId}": {
      "schema": { "title": "Group", "type": "object", "properties": { "name": { "type": "string" }, "allowMemberComments": { "type": "boolean" } } },
      "description": "Photography groups/communities."
    },
    "groups/{groupId}/assignments/{assignmentId}": {
      "schema": { "$ref": "#/backend/entities/GroupAssignment" },
      "description": "Tasks created by group owners."
    },
    "groups/{groupId}/submissions/{submissionId}": {
      "schema": { "$ref": "#/backend/entities/GroupSubmission" },
      "description": "Member photo submissions for assignments."
    },
    "groups/{groupId}/trips/{tripId}": {
      "schema": { "$ref": "#/backend/entities/Trip" },
      "description": "Scheduled photo walks and trips within a group."
    },
    "groups/{groupId}/trips/{tripId}/participants/{userId}": {
      "schema": { "$ref": "#/backend/entities/TripParticipant" },
      "description": "Individual participation status for a trip."
    }
  }
}
