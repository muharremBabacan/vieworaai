
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the Viewora AI Coach application, storing their profile information, token balance, and gamification level.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "auro_balance": { "type": "number" },
        "total_auro_spent": { "type": "number", "default": 0 },
        "total_analyses_count": { "type": "number", "default": 0 },
        "level_name": { "type": "string" },
        "current_xp": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "lastNotificationsViewedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "auro_balance", "level_name", "current_xp", "createdAt"]
    },
    "AnalysisLog": {
      "title": "Analysis Log",
      "type": "object",
      "description": "Individual record of every AI analysis performed for cost and usage tracking.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["technical", "mentor"] },
        "auroSpent": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["userId", "type", "auroSpent", "timestamp"]
    },
    "DailyStats": {
      "title": "Daily Stats",
      "type": "object",
      "description": "Aggregated daily metrics for admin dashboard performance.",
      "properties": {
        "date": { "type": "string" },
        "dau": { "type": "number", "description": "Daily Active Users count" },
        "technicalAnalyses": { "type": "number" },
        "mentorAnalyses": { "type": "number" },
        "photoUploads": { "type": "number" },
        "auroSpent": { "type": "number" },
        "activeUsersList": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and aggregate usage counts."
    },
    "analysis_logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/AnalysisLog" },
      "description": "Central collection for tracking all AI usage events."
    },
    "global_stats/{statId}": {
      "schema": { "$ref": "#/backend/entities/DailyStats" },
      "description": "Daily summary records for the admin dashboard."
    },
    "public_profiles/{userId}": {
      "schema": { "title": "PublicUserProfile", "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "email": { "type": "string" }, "photoURL": { "type": "string" }, "level_name": { "type": "string" } } },
      "description": "Public-facing user profiles."
    }
  }
}
