
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@viewora.ai' ||
        request.auth.uid == '01DT86bQwWUVmrewnEb8c6bd8H43' ||
        request.auth.token.admin == true
      );
    }
    
    //-------------------------------------------------------------------------
    // Collection Rules
    //-------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

       match /transactions/{transactionId} {
         allow read, write: if isOwner(userId) || isAdmin();
       }
       
       match /lessonProgress/{progressId} {
         allow read, write: if isOwner(userId) || isAdmin();
       }

       match /photos/{photoId} {
         allow read, write: if isOwner(userId) || isAdmin();
       }
    }
    
    match /public_profiles/{userId} {
      // Allow searching by email for invites and general visibility
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    match /user_profile_index/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /groups/{groupId} {
      function isMember() {
        return isSignedIn() && (request.auth.uid in resource.data.memberIds || request.auth.uid == resource.data.ownerId);
      }
    
      function isGroupOwner() {
        return isSignedIn() && (request.auth.uid == resource.data.ownerId || isAdmin());
      }
    
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
    
      allow get: if isSignedIn();
      allow list: if isSignedIn();
    
      allow update: if isGroupOwner() || (
        isSignedIn() &&
        !(request.auth.uid in resource.data.memberIds) &&
        request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.memberIds.size() <= resource.data.maxMembers
      );
    
      allow delete: if isGroupOwner();

      match /photos/{photoId} {
        allow read, write: if isMember() || isAdmin();
      }

      match /assignments/{assignmentId} {
        allow read: if isMember() || isAdmin();
        allow write: if isGroupOwner();

        match /submissions/{submissionId} {
          allow read: if isMember() || isAdmin();
          allow create: if isMember() && request.resource.data.userId == request.auth.uid;
          allow update: if isGroupOwner();
          allow delete: if isGroupOwner() || (isMember() && resource.data.userId == request.auth.uid);
        }
      }

      match /competitions/{competitionId} {
        allow read: if isMember() || isAdmin();
        allow write: if isGroupOwner();

        match /entries/{entryId} {
          allow read: if isMember() || isAdmin();
          allow create: if isMember() && request.resource.data.userId == request.auth.uid;
          allow update: if isMember() && request.resource.data.votes == resource.data.votes.concat([request.auth.uid]);
          allow delete: if isGroupOwner() || (isMember() && resource.data.userId == request.auth.uid);
        }
      }

      match /events/{eventId} {
        allow read: if isMember() || isAdmin();
        allow create, delete: if isGroupOwner();
        allow update: if isGroupOwner() || (isMember() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvps', 'rsvps.' + request.auth.uid]));
      }

      match /trainings/{trainingId} {
        allow read: if isMember() || isAdmin();
        allow write: if isGroupOwner();
      }
    }
    
    match /group_invites/{inviteId} {
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow read: if isSignedIn() && 
                    (request.auth.uid == resource.data.toUserId || request.auth.uid == resource.data.fromUserId || isAdmin());
      allow list: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.toUserId || isAdmin());
      allow delete: if isAdmin();
    }

    match /academyLessons/{lessonId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    match /competitions/{competitionId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /entries/{entryId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn() && request.resource.data.votes == resource.data.votes.concat([request.auth.uid]);
        allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      }
    }
    
    match /global_notifications/{notifId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    match /public_photos/{photoId} {
      allow get, list: if isSignedIn(); 
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                    && (
                      (
                        request.auth.uid in request.resource.data.likes &&
                        (!('likes' in resource.data) || !(request.auth.uid in request.resource.data.likes))
                      )
                      ||
                      (
                        !('likes' in request.resource.data && request.auth.uid in request.resource.data.likes) &&
                        'likes' in resource.data && request.auth.uid in request.resource.data.likes
                      )
                    );
    }
  }
}
