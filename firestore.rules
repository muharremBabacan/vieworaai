/**
 * This ruleset enforces a strict user-ownership model for the Viewora AI Coach application.
 *
 * Core Philosophy:
 * The security model is built on the principle of "Authorization Independence". All data
 * private to a user is stored in subcollections under their unique user document.
 * This allows rules to authorize access based on the document path, which is highly
 * secure and performant. Publicly readable data is segregated into its own top-level
 * collection to prevent data leakage and simplify list queries. The default posture is deny-all.
 *
 * Data Structure:
 * - /users/{userId}: Stores the user's private profile.
 * - /users/{userId}/{subcollection}: All user-generated content (photos, lesson progress,
 *   transactions) is nested here. Access is inherited from the parent user's ownership.
 * - /academyLessons/{lessonId}: A top-level collection for public, read-only educational content.
 *
 * Key Security Decisions:
 * - User Isolation: Users can only access their own data tree within /users/{userId}. They
 *   cannot read, write, or even know about the existence of other users' data.
 * - No User Listing: It is not possible to list all documents in the top-level `/users`
 *   collection, protecting user privacy.
 * - Read-Only Public Content: The `/academyLessons` collection is readable by any
 *   authenticated user but cannot be modified by any client. This content must be
 *   managed through a trusted server environment or the Firebase Console.
 * - Denormalization for Authorization: User-specific subcollection documents (e.g., a photo)
 *   contain a `userId` field. This is used not for primary authorization (which is path-based)
 *   but for ensuring data integrity on creation and updates.
 * - Structural Segregation: Private user data (`/users/{userId}`) is structurally
 *   separate from public data (`/academyLessons`), which is a critical pattern for
 *   securing list operations and preventing accidental data exposure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Checks if the user is an admin based on their email.
     * Used for cross-user data access for reporting.
     * IMPORTANT: Using email for authorization is not a best practice for production
     * systems. Custom claims are a more secure alternative. This is for prototyping.
     */
    function isAdmin() {
      return request.auth.token.email == 'babacan.muharrem@gmail.com';
    }

    /**
     * A robust check for update/delete operations, ensuring the user is the
     * owner AND the document actually exists before the operation.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    //-------------------------------------------------------------------------
    // Validation Functions (Prototyping Mode: Authorization-critical fields only)
    //-------------------------------------------------------------------------

    /**
     * Validates the integrity of a new User document on create.
     * Ensures the document's internal `id` matches the document's path ID.
     */
    function hasValidNewUserData(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Validates the integrity of a new subcollection document on create.
     * Ensures the document's internal `userId` field is correctly set to the owner's UID from the path.
     */
    function hasValidNewChildData(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * Validates that critical relational fields in a subcollection document are immutable.
     * Prevents re-assigning a document (e.g., a photo) to a different user.
     */
    function isChildDataImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    //-------------------------------------------------------------------------
    // Collection Rules
    //-------------------------------------------------------------------------

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (get) Any authenticated user can read a user profile. (Needed for group features).
     * @allow (create, update) A user can create or update their own document.
     * @deny (list, delete) Listing all users or deleting users is forbidden.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && hasValidNewUserData(userId);
      allow update: if isOwner(userId) && resource != null;
      allow delete: if false;

      /**
       * @description Controls access to photos submitted by a user.
       * @path /users/{userId}/photos/{photoId}
       * @allow (create, get, list, update, delete) A user managing their own photos.
       * @deny (create, get, list, update, delete) Any user trying to access another user's photos.
       * @principle Enforces strict document ownership within a user's private data tree.
       */
      match /photos/{photoId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidNewChildData(userId);
        allow update: if isExistingOwner(userId) && isChildDataImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Controls access to a user's lesson progress.
       * @path /users/{userId}/lessonProgress/{progressId}
       * @allow (create, get, list, update, delete) A user managing their own lesson progress.
       * @deny (create, get, list, update, delete) Any user trying to access another user's progress.
       * @principle Enforces strict document ownership within a user's private data tree.
       */
      match /lessonProgress/{progressId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidNewChildData(userId);
        allow update: if isExistingOwner(userId) && isChildDataImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Controls access to a user's financial and token transactions.
       * @path /users/{userId}/transactions/{transactionId}
       * @allow (create, get, list, update, delete) A user managing their own transaction history.
       * @deny (create, get, list, update, delete) Any user trying to access another user's transactions.
       * @principle Enforces strict document ownership for sensitive financial data.
       */
      match /transactions/{transactionId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidNewChildData(userId);
        allow update: if isExistingOwner(userId) && isChildDataImmutable();
        allow delete: if isExistingOwner(userId);
      }
    }
    
    /**
     * @description Controls access to user-created groups.
     * @path /groups/{groupId}
     * @allow (get) Any authenticated user. Needed for join-by-link/code functionality.
     * @allow (list) Only for querying by a specific joinCode.
     * @allow (create) Any signed-in user who sets themselves as owner.
     * @allow (update) The group owner OR a user joining the group.
     * @allow (delete) Only the group owner.
     */
    match /groups/{groupId} {
        function isGroupOwner() {
          return isSignedIn() && request.auth.uid == resource.data.ownerId;
        }

        // Helper function to check if the only change is a user adding themselves to memberIds
        function isJoiningGroup() {
          // The user must be authenticated.
          if (!isSignedIn()) {
            return false;
          }
          
          // The incoming member list must be exactly the old list plus the new user.
          let isAddingSelf = request.resource.data.memberIds == resource.data.memberIds.concat([request.auth.uid]);
          
          // No other fields can be changed.
          // The only key allowed to change is 'memberIds'.
          let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
          
          return isAddingSelf && changedKeys.size() == 1 && changedKeys.hasAny(['memberIds']);
        }
        
        // Allow any authenticated user to read group details.
        // This is necessary for join flows where a non-member needs to read group info.
        allow get: if isSignedIn();
        
        // Allow querying the groups collection ONLY when looking for a specific join code.
        allow list: if isSignedIn() && request.query.keys().hasOnly(['joinCode']) && request.query.limit == 1;

        // Allow creating a group if the user sets themselves as owner and initial member.
        allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId && request.auth.uid in request.resource.data.memberIds;
        
        // Allow owner to update OR a user to join the group.
        allow update: if isGroupOwner() || isJoiningGroup();
        
        // Allow owner to delete the group.
        allow delete: if isGroupOwner();

      /**
       * @description Controls access to a group's shared photo gallery.
       * @path /groups/{groupId}/photos/{photoId}
       * @allow (get, list) Any member of the parent group.
       * @allow (create) Any member of the parent group.
       * @allow (delete) The user who uploaded the photo, or the group owner.
       * @principle Inherits read/write permissions from the parent group's membership.
       */
      match /photos/{photoId} {
        function parentGroupIsMember() {
          let groupDoc = get(/databases/$(database)/documents/groups/$(groupId));
          return isSignedIn() && groupDoc != null && request.auth.uid in groupDoc.data.memberIds;
        }

        function isGroupOrPhotoOwner() {
          let groupDoc = get(/databases/$(database)/documents/groups/$(groupId));
          let isPhotoOwner = request.auth.uid == resource.data.userId;
          let isGroupOwner = groupDoc != null && isSignedIn() && request.auth.uid == groupDoc.data.ownerId;
          return isPhotoOwner || isGroupOwner;
        }

        allow get, list: if parentGroupIsMember();
        allow create: if parentGroupIsMember() && hasValidNewChildData(request.auth.uid);
        allow update: if false; // Photos are immutable once posted to a group gallery
        allow delete: if isGroupOrPhotoOwner();
      }
    }


    /**
     * @description Controls access to public academy lessons.
     * @path /academyLessons/{lessonId}
     * @allow (get, list) Any authenticated user can read the academy lessons.
     * @allow (create) Any authenticated user can create lessons (for the admin tool).
     * @deny (update, delete) All client-side writes are forbidden to protect content integrity.
     * @principle Provides public read access while allowing creation from admin tools.
     */
    match /academyLessons/{lessonId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to public photos submitted by users to the gallery.
     * @path /public_photos/{photoId}
     * @allow (get, list) Any authenticated user can read the public gallery photos.
     * @allow (create) An authenticated user can submit their own photo (validating ownership via userId field).
     * @allow (delete) The owner of the photo can withdraw it from the public gallery.
     * @deny (update) All client-side updates are forbidden.
     * @principle Provides public read access, controlled/validated writes, and owner-only deletes.
     */
    match /public_photos/{photoId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    /**
     * @description Allows an admin user to list all transactions across all users for reporting.
     * @path /users/{userId}/transactions/{transactionId} (via collection group)
     * @allow (list) An admin user for generating revenue reports.
     * @deny (list) All other users.
     * @principle Provides read-only access to a specific role for aggregated data analysis.
     */
    match /{path=**}/transactions/{transactionId} {
      allow list: if isAdmin();
    }
  }
}
