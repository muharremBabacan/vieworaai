
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@viewora.ai' ||
        request.auth.token.email == 'babacan.muharrem@gmail.com' ||
        request.auth.uid == '01DT86bQwWUVrewnEb8c6bd8H43' ||
        request.auth.uid == 'BLxfoAPsRyOMTkrKD9EoLtt47Fo1' ||
        request.auth.token.admin == true
      );
    }

    // --- PIX PACKAGES ---
    match /pix_packages/{packageId} {
      allow get, list: if true; 
      allow write: if isAdmin();
    }

    // --- PIX PURCHASES ---
    match /pix_purchases/{purchaseId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow list: if isAdmin(); 
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin();
      
      match /photos/{photoId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /strategic_feedbacks/{feedbackId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // --- OTHER COLLECTIONS ---
    match /exhibitions/{exhibitionId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /public_photos/{photoId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /groups/{groupId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /assignments/{assignmentId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin() || (get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid);
      }

      match /submissions/{submissionId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }

      match /trips/{tripId} {
        allow get, list: if isSignedIn();
        allow create, update: if isSignedIn();
        
        match /participants/{userId} {
          allow get, list: if isSignedIn();
          allow create, update: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }

    match /app_settings/{docId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /analysis_logs/{logId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn();
    }

    match /public_profiles/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /academy_curriculum/{docId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /academy_lessons/{lessonId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
