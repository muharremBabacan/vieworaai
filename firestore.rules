/**
 * This ruleset enforces a strict user-ownership model for the Viewora AI Coach application.
 *
 * Core Philosophy:
 * The security model is built on the principle of "Authorization Independence". All data
 * private to a user is stored in subcollections under their unique user document.
 * This allows rules to authorize access based on the document path, which is highly
 * secure and performant. Publicly readable data is segregated into its own top-level
 * collection to prevent data leakage and simplify list queries. The default posture is deny-all.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    //-------------------------------------------------------------------------
    // Collection Rules
    //-------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // IMPORTANT: Prevents listing all app users.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if false;

       match /{allPaths=**} {
         allow read, write: if isOwner(userId);
       }
    }
    
    match /groups/{groupId} {
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberIds;
      }
    
      function isOwner() {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }
    
      allow create: if isSignedIn() &&
                     request.auth.uid == request.resource.data.ownerId;
    
      allow get: if isMember();
    
      // Allow LIST operations (queries) for any authenticated user.
      // The actual documents returned are still secured by the GET rule.
      allow list: if isSignedIn();
    
      // Allow owners to update group details.
      // Allow a user to add THEMSELVES to the memberIds array, but not others.
      // This is the secure way to handle a "join" or "accept invite" action.
      allow update: if isOwner() ||
                     (isSignedIn() && request.resource.data.memberIds == resource.data.memberIds.concat([request.auth.uid]));
    
      allow delete: if isOwner();

      match /photos/{photoId} {
        allow read, write: if isMember();
      }
    }
    
    match /group_invites/{inviteId} {
      // Allow any authenticated user to create an invitation.
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
    
      // Allow a user to read an invite if they sent it or if it was sent to them.
      allow read: if isSignedIn() && 
                    (request.auth.uid == resource.data.toUserId || request.auth.uid == resource.data.fromUserId);
    
      // Allow queries on the collection (e.g., `where('toUserId', '==', uid)`).
      // The read rule above will secure the individual documents in the result.
      allow list: if isSignedIn();

      // Only the recipient of the invite can update its status (e.g., to "accepted" or "declined").
      allow update: if isSignedIn() && request.auth.uid == resource.data.toUserId;
    
      // For simplicity and to keep a record, direct deletion is disallowed.
      // Invites are "processed" by changing their status.
      allow delete: if false;
    }

    match /academyLessons/{lessonId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Managed via Admin tools or Console
    }
    
    match /public_photos/{photoId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
  }
}

    