
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@viewora.ai' ||
        request.auth.token.email == 'babacan.muharrem@gmail.com' ||
        request.auth.uid == '01DT86bQwWUVrewnEb8c6bd8H43' ||
        request.auth.uid == 'BLxfoAPsRyOMTkrKD9EoLtt47Fo1' ||
        request.auth.token.admin == true
      );
    }

    function isGroupMember(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)) && 
             (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds ||
              get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid);
    }

    function isGroupOwner(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)) && 
             get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
    }
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin();
      
      match /photos/{photoId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /strategic_feedbacks/{feedbackId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /notifications/{notifId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }
    
    match /exhibitions/{exhibitionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /public_photos/{photoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /competitions/{competitionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /entries/{entryId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }
    
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /assignments/{assignmentId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if isGroupOwner(groupId);
      }

      match /submissions/{submissionId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && request.resource.data.userId == request.auth.uid;
        allow update: if isGroupMember(groupId);
        allow delete: if isGroupOwner(groupId) || (isGroupMember(groupId) && resource.data.userId == request.auth.uid);
      }

      match /trips/{tripId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupOwner(groupId);
        allow update: if isGroupMember(groupId);
        allow delete: if false;

        match /participants/{userId} {
          allow read: if isGroupMember(groupId);
          allow create, update: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }

    match /trip_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /analysis_logs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn();
    }
    
    match /global_stats/{statId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn();
    }

    match /public_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /group_invites/{inviteId} {
      allow read: if isSignedIn() && (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /global_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /academy_lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /academy_curriculum/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pix_packages/{packageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pix_purchases/{purchaseId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
