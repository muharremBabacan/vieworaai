rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User-specific uploads
    // A user can read, write, and delete files inside their own user-specific folder.
    // This allows them to upload for analysis, practice submissions, and manage their own content.
    // The path /{allPaths=**} is a recursive wildcard, granting access to all files and folders
    // under the user's directory.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Publicly readable academy lesson images
    // The admin can write (upload/update/delete) lesson images.
    // Any authenticated user can read them.
    match /academy-lessons/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'admin@viewora.ai';
    }
  }
}
