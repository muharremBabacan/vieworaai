rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User-specific uploads
    // A user can read, write, and delete files inside their own user-specific folder.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ⭐ VIEWORA ACADEMY (ADMIN UPLOAD)
    // This rule allows users with an 'admin' custom claim to write to the
    // /academy-lessons/ folder. All other authenticated users can only read.
    match /academy-lessons/{allPaths=**} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth.token.admin == true;
    }
  }
}
