
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Admin Helper
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@viewora.ai' ||
        request.auth.uid == '01DT86bQwWUVmrewnEb8c6bd8H43' ||
        request.auth.token.admin == true
      );
    }

    // User-specific uploads (Academy practice, personal photos, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Competition Entries
    match /competitions/{competitionId}/entries/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Academy Lessons (Admin Upload)
    match /academy-lessons/{allPaths=**} {
      allow read: if request.auth != null;
      allow write, delete: if isAdmin();
    }
    
    // Public uploads
    match /public-uploads/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
