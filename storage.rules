rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User-specific uploads
    // A user can read, write, and delete files inside their own user-specific folder.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ⭐ VIEWORA ACADEMY (ADMIN YÜKLEME)
    // Bu kural, "admin" custom claim'ine sahip olan kullanıcıların
    // /academy-lessons/ klasörüne yazmasına (yükleme, silme) izin verir.
    // Diğer tüm kimliği doğrulanmış kullanıcılar yalnızca okuyabilir.
    match /academy-lessons/{lessonId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
